<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <!--
      Bluetooth-relay sync: API ≤ 30 использует legacy BLUETOOTH/BLUETOOTH_ADMIN
      + ACCESS_FINE_LOCATION (он уже выше). API 31+ — runtime-perm'ы SCAN/
      CONNECT/ADVERTISE (neverForLocation мы не ставим, иначе нельзя
      сканировать другие устройства, привязанные к гео).
    -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <!--
      `neverForLocation` важен на Samsung/Xiaomi/MIUI: без него OEM-прошивки
      на Android 12+ иногда тихо режут результаты сканирования (даже если
      permission выдан), считая, что приложение пытается определить локацию
      через BT. Мы локацию через BT не выводим — рядом стоящие телефоны
      сравниваем по адресу/имени, а не по геопозиции.
    -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Android 11+ (targetSdk 30+) ограничивает видимость других приложений.
      Без <queries> вызовы PackageManager.resolveActivity() для geo:/https:
      возвращают null даже когда Maps установлены, и кнопки «На карте» /
      «Маршрут» в деталях места молча ничего не делают.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="google.navigation" />
        </intent>
        <package android:name="com.google.android.apps.maps" />
        <package android:name="ru.yandex.yandexmaps" />
        <package android:name="ru.yandex.yandexnavi" />
    </queries>

    <application
        android:name=".TrilooApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Triloo"
        tools:targetApi="34">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Triloo.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".data.location.LocationSharingForegroundService"
            android:exported="false"
            android:foregroundServiceType="location" />
    </application>

</manifest>
