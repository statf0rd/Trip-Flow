<?xml version="1.0" encoding="utf-8"?>
<!--
  Сетевая политика приложения Triloo.
  HTTPS-only: cleartext-трафик запрещён по умолчанию и не разрешён ни для одного домена.
  Backend Triloo теперь работает по HTTPS (Caddy + Lets Encrypt).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
